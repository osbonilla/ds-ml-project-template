# Entornos Virtuales
.venv/
venv/
env/
.env

# Caché y artefactos de Python
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# Jupyter Notebooks
.ipynb_checkpoints/

# Directorio de Datos (NO SUBIR DATOS A GIT POR DEFECTO)
data/raw/
data/interim/
data/processed/
data/external/

# Mantener la estructura de carpetas de datos aunque estén vacías
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Modelos
models/
!models/.gitkeep

# Mac OS
.DS_Store

# Archivos de configuración local
.env.local

# IDEs
.vscode/
.idea/
*.code-workspace

# Logs de uvicorn / FastAPI
*.log

# Distribución / empaquetado
dist/
build/
*.egg-info/

# mypy / type checking
.mypy_cache/